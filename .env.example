# Deze variabelen worden automatisch ingesteld door Vercel
# wanneer je Upstash Redis vanuit de Vercel Marketplace toevoegt.
# Voor lokale ontwikkeling: `vercel env pull .env.development.local`

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optioneel: simpele gedeelde PIN voor het gezin.
# Niet ingevuld = iedereen met de URL kan bewerken (open toegang).
# Wel ingevuld = bij eerste bezoek wordt om de PIN gevraagd.
FAMILY_PIN=
